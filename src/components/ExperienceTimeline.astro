---
import type { Experience } from '../data/experience';

export interface Props {
  experiences: Experience[];
}

const { experiences } = Astro.props;
---

<div class="relative">
  <div class="absolute left-4 top-0 bottom-0 w-px bg-slate-200 ml-0.5"></div>
  <div class="space-y-10">
    {experiences.map((exp) => (
      <div class="relative pl-12">
        <div class="absolute left-0 top-1.5 w-3 h-3 bg-accent rounded-full border-2 border-white shadow-sm"></div>
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
          <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
            <h3 class="font-serif text-lg font-semibold text-primary">{exp.org}</h3>
            <span class="font-mono text-xs text-slate-500 bg-slate-50 px-2 py-1 rounded border border-slate-200 whitespace-nowrap">
              {exp.period}
            </span>
          </div>
          <p class="text-accent font-medium text-sm mb-1">{exp.role}</p>
          <p class="text-slate-400 text-xs mb-4">{exp.location}</p>
          <ul class="space-y-1.5">
            {exp.bullets.map((bullet) => (
              <li class="text-slate-600 text-sm flex gap-2">
                <span class="text-accent mt-1 flex-shrink-0" aria-hidden="true">▸</span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
          <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-slate-100">
            {exp.tags.map((tag) => (
              <span class="font-mono text-xs bg-slate-100 text-slate-500 px-2 py-0.5 rounded">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
