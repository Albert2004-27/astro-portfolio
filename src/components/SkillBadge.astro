---
import type { SkillGroup } from '../data/skills';

export interface Props {
  groups: SkillGroup[];
  compact?: boolean;
}

const { groups, compact = false } = Astro.props;

const levelColors: Record<number, string> = {
  1: 'bg-slate-100 text-slate-600 border-slate-200',
  2: 'bg-blue-50 text-blue-700 border-blue-200',
  3: 'bg-blue-100 text-blue-800 border-blue-300',
};
---

<div class={compact ? 'flex flex-wrap gap-6' : 'grid grid-cols-1 md:grid-cols-2 gap-8'}>
  {groups.map((group) => (
    <div>
      <h3 class="font-serif text-base font-semibold text-primary mb-3">{group.category}</h3>
      <div class="flex flex-wrap gap-2">
        {group.skills.map((skill) => (
          <span class={`font-mono text-xs px-2.5 py-1 rounded-md border ${levelColors[skill.level]} cursor-default`}>
            {skill.name}
          </span>
        ))}
      </div>
    </div>
  ))}
</div>
