---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillBadge from '../components/SkillBadge.astro';
import { skillGroups } from '../data/skills';
---

<BaseLayout
  title="Skills"
  description="Albert Chen's technical skills in quantitative finance and machine learning."
>
  <div class="max-w-6xl mx-auto px-4 py-20">
    <p class="text-accent font-mono text-sm uppercase tracking-widest mb-3">Toolkit</p>
    <h1 class="font-serif text-4xl font-bold text-primary mb-4">Skills</h1>
    <p class="text-slate-500 max-w-xl mb-4">
      Technologies and tools across quantitative finance, ML/RL, and data engineering.
    </p>
    <div class="flex flex-wrap gap-4 mb-12 text-xs font-mono text-slate-500">
      <span class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded bg-slate-100 border border-slate-200 inline-block"></span>
        Familiar
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded bg-blue-50 border border-blue-200 inline-block"></span>
        Proficient
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded bg-blue-100 border border-blue-300 inline-block"></span>
        Expert
      </span>
    </div>
    <SkillBadge groups={skillGroups} compact={false} />
  </div>
</BaseLayout>
