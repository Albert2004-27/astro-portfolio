---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SkillBadge from '../components/SkillBadge.astro';
import { projects } from '../data/projects';
import { skillGroups } from '../data/skills';

const featured = projects.filter((p) => p.featured);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <!-- Hero -->
  <Hero />

  <!-- About -->
  <section class="py-20 px-4 bg-white border-t border-slate-100">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-accent font-mono text-sm uppercase tracking-widest mb-3">About</p>
          <h2 class="font-serif text-3xl font-bold text-primary mb-6">Who I Am</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            Senior student at NCCU (Money &amp; Banking + Statistics, Top 5%) and incoming NTU
            Finance Master's student. My research centers on applying deep reinforcement learning
            to portfolio management — building TD3 agents with custom fusion reward functions
            that jointly optimize Sharpe ratio, alpha, drawdown, and cash timing.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            Currently interning as a Quant Analyst at TEJ, building financial data pipelines
            and backtesting workflows with TQuantLib. Previously at RGA (data analytics for
            actuarial reporting) and Academia Sinica IIS (RL portfolio research achieving
            Sharpe &gt; 1.5 vs benchmarks).
          </p>
          <p class="text-slate-600 leading-relaxed">
            Outside of quant work: 17 years of classical piano, forex trading (4 years),
            competitive billiards, and YouTube content creation (1,800+ subscribers).
          </p>
        </div>
        <div class="bg-slate-50 rounded-xl p-8 border border-slate-200">
          <dl class="space-y-6">
            <div>
              <dt class="font-mono text-xs text-slate-400 uppercase tracking-widest mb-1">Education</dt>
              <dd class="text-slate-800 font-medium">NCCU Finance + Statistics</dd>
              <dd class="text-slate-500 text-sm">→ NTU Finance M.S. (Sep 2026)</dd>
            </div>
            <div>
              <dt class="font-mono text-xs text-slate-400 uppercase tracking-widest mb-1">Research</dt>
              <dd class="text-slate-800 font-medium">RL Portfolio Management</dd>
              <dd class="text-slate-500 text-sm">Academia Sinica</dd>
            </div>
            <div>
              <dt class="font-mono text-xs text-slate-400 uppercase tracking-widest mb-1">Industry</dt>
              <dd class="text-slate-800 font-medium">Quant Analyst · Data Analyst</dd>
              <dd class="text-slate-500 text-sm">TEJ · RGA</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <p class="text-accent font-mono text-sm uppercase tracking-widest mb-3">Work</p>
      <h2 class="font-serif text-3xl font-bold text-primary mb-2">Featured Projects</h2>
      <p class="text-slate-500 mb-10">Selected work in quantitative finance and machine learning.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {featured.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            github={project.github}
            demo={project.demo}
          />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href={`${base}projects`} class="text-accent font-medium hover:text-blue-700 transition-colors duration-200 cursor-pointer">
          View all projects →
        </a>
      </div>
    </div>
  </section>

  <!-- Skills Summary -->
  <section class="py-20 px-4 bg-white border-t border-slate-100">
    <div class="max-w-6xl mx-auto">
      <p class="text-accent font-mono text-sm uppercase tracking-widest mb-3">Toolkit</p>
      <h2 class="font-serif text-3xl font-bold text-primary mb-2">Skills</h2>
      <p class="text-slate-500 mb-10">Tools and technologies I work with regularly.</p>
      <SkillBadge groups={skillGroups} compact={true} />
      <div class="mt-8 text-center">
        <a href={`${base}skills`} class="text-accent font-medium hover:text-blue-700 transition-colors duration-200 cursor-pointer">
          View full skills breakdown →
        </a>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-20 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <p class="text-accent font-mono text-sm uppercase tracking-widest mb-3">Contact</p>
      <h2 class="font-serif text-3xl font-bold text-primary mb-4">Get In Touch</h2>
      <p class="text-slate-500 max-w-lg mx-auto mb-10">
        Open to research collaborations, quant roles, and interesting conversations.
      </p>
      <div class="flex flex-wrap justify-center gap-8">
        <a
          href="https://github.com/Albert2004-27"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-slate-600 hover:text-accent transition-colors duration-200 cursor-pointer font-medium"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
        <a
          href="mailto:Albertchen0227@gmail.com"
          class="flex items-center gap-2 text-slate-600 hover:text-accent transition-colors duration-200 cursor-pointer font-medium"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Email
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
